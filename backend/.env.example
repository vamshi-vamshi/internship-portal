# ============================================================
# BACKEND ENVIRONMENT VARIABLES
# ============================================================
# Copy to .env for local development, or set in Render dashboard

# ----- PostgreSQL (Render) -----
# Render provides this as "External Database URL" — prepend jdbc:postgresql://
DATABASE_URL=jdbc:postgresql://your-render-host.oregon-postgres.render.com:5432/internship_portal_xxxx
DB_USERNAME=internship_portal_xxxx_user
DB_PASSWORD=yourpasswordhere

# ----- JWT -----
# Generate a random 64+ character string
JWT_SECRET=change-this-to-a-long-random-secret-at-least-64-characters-long-abc123

# ----- CORS -----
# Comma-separated, no trailing slash, no spaces
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# ----- Server Port -----
# Render sets this automatically — do NOT hardcode on Render
PORT=8080

# ----- AI Chatbot (optional) -----
AI_ENABLED=false
AI_API_KEY=
