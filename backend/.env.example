# ===== PostgreSQL (Render) =====
DATABASE_URL=jdbc:postgresql://your-render-host:5432/internship_portal
DB_USERNAME=your_pg_username
DB_PASSWORD=your_pg_password

# ===== JWT =====
JWT_SECRET=YourSuperLongSecretKeyAtLeast256CharactersLong1234567890ABCDEFGHIJ
JWT_EXPIRATION=86400000

# ===== CORS (add your Vercel URL) =====
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# ===== Admin Account (created on startup if missing) =====
ADMIN_EMAIL=admin@portal.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Admin User

# ===== AI Chatbot (optional) =====
AI_ENABLED=false
AI_API_KEY=

# ===== Server =====
PORT=8080
