# ============================================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env (local dev) or set in Vercel dashboard
#
# LOCAL DEVELOPMENT:
#   VITE_API_BASE_URL=http://localhost:8080/api
#   (vite.config.js proxy handles /api → :8080 in dev mode
#    so this var is NOT needed for local dev — leave blank or omit)
#
# PRODUCTION (Vercel):
#   Set VITE_API_BASE_URL to your Render backend URL:
VITE_API_BASE_URL=https://your-internship-backend.onrender.com/api
